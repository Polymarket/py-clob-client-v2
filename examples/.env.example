RPC_URL=https://rpc-amoy.polygon.technology

CLOB_API_URL=
CLOB_AUTH_URL=

GAMMA_API_URL=

BUILDER_PK=0x...
USER_A_PK=0x...
USER_B_PK=0x...

COLLATERAL_TOKEN_ADDRESS=0x...
WRAPPER_ADDRESS=0x...

# Optional: specific market to trade
# CONDITION_ID=0xbd5e4a45c3d9db4acae940913ec32a89fb6402c0475170e58b90fb499b73d7af
# YES_TOKEN_ID=102200530570339469387764365697342150521708074903735836831685780223982723092914
# NO_TOKEN_ID=15871154585880608648532107628464183779895785213830018178010423617714102767076

# Builder fee configuration (basis points)
# BUILDER_MAKER_FEE_BPS=50
# BUILDER_TAKER_FEE_BPS=200

# Order parameters
# ORDER_PRICE=0.5
# ORDER_SIZE=100

# Optional: balance updater service URL
# BALANCE_UPDATER_URL=

# Optional: builder service URL for querying trades
# BUILDER_SERVICE_URL=

# Optional: SIWE domain (default: polymarket.com)
# DOMAIN=polymarket.com

# Optional: seconds to wait after creating a fresh API key (default: 30)
# API_KEY_COOLDOWN_SEC=30
